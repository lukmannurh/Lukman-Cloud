# ─── Lukman Cloud — Environment Variables Template ───────────────────────────
# Copy this file to .env.local for local development.
# All variables prefixed with VITE_ are embedded in the browser bundle at build
# time by Vite. DO NOT put server-side secrets here.
#
# In production: configure ALL variables in the Vercel dashboard under
# Project Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────

# ── Google OAuth 2.0 (PKCE) ──────────────────────────────────────────────────
# Create at: console.cloud.google.com → APIs & Services → Credentials
# Application type: Web Application
# Authorized redirect URIs: https://your-app.vercel.app/oauth/callback
VITE_GOOGLE_CLIENT_ID=

# The redirect URI registered in Google Cloud Console
# For local dev: http://localhost:5173/oauth/callback
VITE_GOOGLE_REDIRECT_URI=http://localhost:5173/oauth/callback

# ── Telegram MTProto ──────────────────────────────────────────────────────────
# Obtain from https://my.telegram.org/apps
# API ID is a numeric integer (e.g. 12345678)
VITE_TELEGRAM_API_ID=
# API Hash is a 32-character hex string
VITE_TELEGRAM_API_HASH=

# ── TOTP Access Code Gate ─────────────────────────────────────────────────────
# Base32-encoded TOTP secret (RFC 4648 Base32 alphabet: A-Z and 2-7)
#
# HOW TO GENERATE:
#   python3 -c "import base64, secrets; print(base64.b32encode(secrets.token_bytes(20)).decode())"
#   OR use: openssl rand -base64 20 | base32
#
# HOW TO USE IN AUTHENTICATOR APP:
#   Use an app that supports CUSTOM TOTP PERIODS:
#   ✅ Aegis Authenticator (Android) — recommended
#   ✅ andOTP (Android)
#   ✅ 1Password
#   ✅ Bitwarden
#   ❌ Google Authenticator — does NOT support 300s periods
#
#   Manual entry settings:
#     Account name: Lukman Cloud
#     Secret key: <value of VITE_APP_TOTP_SECRET>
#     Type: Time-based (TOTP)
#     Algorithm: SHA1
#     Digits: 6
#     Period: 300 seconds  ← CRITICAL: must be 300, NOT 30
#
# HOW TO SHARE WITH FAMILY:
#   Simply open your authenticator app and read the current 6-digit code.
#   The code is valid for 5 minutes. Share it via secure channel (WhatsApp, Signal).
VITE_APP_TOTP_SECRET=

# TOTP time period in seconds (default: 300 = 5 minutes)
# Do NOT change this unless your authenticator app is also reconfigured.
VITE_APP_TOTP_PERIOD=300

# ── App Metadata ──────────────────────────────────────────────────────────────
VITE_APP_VERSION=0.1.0
